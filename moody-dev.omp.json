{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "comment": "Palette de couleurs (direction artistique sombre, accents bleu/cyan/magenta). Utilisée pour cohérence visuelle.",
  "palette": {
    "accent_blue": "#7aa2f7",
    "accent_cyan": "#7dcfff",
    "accent_green": "#9ece6a",
    "accent_magenta": "#bb9af7",
    "accent_orange": "#e0af68",
    "accent_red": "#f7768e",
    "background": "#1a1b26",
    "text": "#c0caf5",
    "git_bg": "#7aa2f7",
    "path_bg": "#1f2335"
  },
  "secondary_prompt": {
    "template": "\u2026 ",
    "foreground": "p:accent_blue"
  },
  "transient_prompt": {
    "template": "❯ ",
    "foreground": "p:accent_blue"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "p:text",
          "properties": {
            "windows": "\ue62a",
            "macos": "\uf179",
            "linux": "\uf17c",
            "template": "{{ .Icon }} "
          }
        },
        {
          "type": "root",
          "style": "plain",
          "foreground": "p:accent_red",
          "properties": {
            "root_icon": "\uf0e7",
            "template": "<bold>ADMIN {{ .Icon }}</> "
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:accent_blue",
          "properties": {
            "time_format": "15:04"
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:text",
          "background": "p:path_bg",
          "properties": {
            "enable_hyperlink": true,
            "folder_icon": "\uf115",
            "home_icon": "\uf015",
            "max_depth": 3,
            "style": "agnoster"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "#1d202f",
          "background": "p:git_bg",
          "properties": {
            "branch_icon": "\ue725 ",
            "display_stash_count": true,
            "display_upstream_icon": true,
            "fetch_status": true,
            "template": "{{ .UpstreamIcon }}{{ .Branch }}{{ if .Working.Added }} +{{ .Working.Added }}{{ end }}{{ if .Working.Modified }} ~{{ .Working.Modified }}{{ end }}{{ if .Working.Deleted }} -{{ .Working.Deleted }}{{ end }}{{ if .StashCount }} 📦{{ .StashCount }}{{ end }}"
          }
        },
        {
          "comment": "Ce segment sert juste à fermer proprement la flèche Git vers le fond transparent",
          "type": "text",
          "style": "plain",
          "foreground": "p:git_bg",
          "properties": {
            "text": "\ue0c6"
          }
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:accent_green",
          "properties": {
            "display_mode": "files",
            "fetch_package_manager": true,
            "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}\uf898 {{ .Full }}"
          }
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:accent_orange",
          "properties": {
            "display_mode": "context",
            "max_depth": 4,
            "template": " \ue606 {{ .Venv }}"
          }
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:accent_cyan",
          "properties": {
            "display_mode": "files",
            "template": " \ue627 {{ .Full }}"
          }
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "p:accent_orange",
          "properties": {
            "display_mode": "files",
            "template": " \ue7a8 {{ .Full }}"
          }
        },
        {
          "type": "java",
          "style": "plain",
          "foreground": "p:accent_red",
          "properties": {
            "display_mode": "files",
            "template": " \ue256 {{ .Full }}"
          }
        },
        {
          "type": "docker",
          "style": "plain",
          "foreground": "p:accent_cyan",
          "properties": {
            "display_mode": "files",
            "template": " \uf308 {{ .Context }}"
          }
        },
        {
          "type": "kubernetes",
          "style": "plain",
          "foreground": "p:accent_cyan",
          "properties": {
            "display_mode": "env",
            "template": " \u2388 {{ .Context }}:{{ .Namespace }}"
          }
        },
        {
          "type": "aws",
          "style": "plain",
          "foreground": "p:accent_red",
          "properties": {
            "display_mode": "env",
            "template": " \uf270 {{ .Profile }}@{{ .Region }}"
          }
        },
        {
          "type": "az",
          "style": "plain",
          "foreground": "p:accent_blue",
          "properties": {
            "display_mode": "env",
            "template": " \ufd03 {{ .Name }}"
          }
        },
        {
          "type": "gcp",
          "style": "plain",
          "foreground": "p:accent_magenta",
          "properties": {
            "display_mode": "env",
            "template": " \uf992 {{ .Project }}"
          }
        },
        {
          "type": "ipify",
          "style": "plain",
          "foreground": "p:accent_cyan",
          "properties": {
            "template": " \ufb4e {{ .IP }}"
          }
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:accent_red",
          "properties": {
            "always_enabled": true,
            "template": "{{ if .Code }} ✗ {{ .Code }}{{ end }}"
          }
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:accent_blue",
          "properties": {
            "text": "❯"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "spotify",
          "style": "plain",
          "foreground": "#1db954",
          "properties": {
            "playing_icon": "\uf1bc ",
            "paused_icon": "\uf04c ",
            "stopped_icon": "\uf04d ",
            "template": "{{ .Icon }}{{ if ne .Status \"stopped\" }}{{ .Artist }} - {{ .Track }}{{ end }} "
          }
        },
        {
          "type": "battery",
          "style": "plain",
          "foreground": "p:text",
          "properties": {
            "charging_icon": "\uf0e7",
            "charging_threshold": 95,
            "discharging_icon": "\uf582",
            "template": "{{ if .Error }}{{ else }}{{ .Icon }} {{ .Percentage }}% {{ end }}"
          }
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:accent_magenta",
          "properties": {
            "template": "\u23f1 {{ .Milliseconds }}ms",
            "threshold": 0
          }
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}